---
import site from '../../content/site.json'
const fullText = [site.manifesto.text_1, site.manifesto.text_2].filter(Boolean).join(' ')
const words = fullText.split(' ');
---

<section class="manifesto-section relative bg-brand-black overflow-hidden"
         style="padding:max(18vh,7rem) 2rem max(18vh,7rem) 2rem;">

  <!-- Linke Akzentlinie -->
  <div class="absolute left-0 top-0 bottom-0 w-px"
       style="background:linear-gradient(to bottom,transparent,rgba(16,178,173,0.2) 25%,rgba(16,178,173,0.2) 75%,transparent);">
  </div>

  <div class="max-w-5xl mx-auto" style="padding-left:4rem;">

    <!-- Label -->
    <p class="font-body text-xs tracking-[0.3em] uppercase mb-16"
       style="color:#10b2ad; opacity:0; transform:translateY(20px);"
       data-fade-in>
      <!-- CUSTOMIZE: Section-Label -->
      Warum die Firma
    </p>

    <!-- Word Reveal — flex+wrap, kleinere Schrift, weniger Zeilenabstand -->
    <div class="font-headline text-brand-white"
         style="font-size:clamp(1.4rem,3.2vw,3rem);line-height:1.42;display:flex;flex-wrap:wrap;gap:0.32em;align-items:baseline;">
      {words.map((word) => (
        <span class="manifesto-word" style="opacity:0;color:#10b2ad;display:inline-block;">{word}</span>
      ))}
    </div>

  </div>
</section>
