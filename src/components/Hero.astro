---
---

<section class="relative flex flex-col items-center justify-center overflow-hidden bg-brand-black"
         style="min-height:100svh;">

  <!-- Noise Textur -->
  <div class="absolute inset-0 pointer-events-none z-10"
    style="opacity:0.032;background-image:url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');background-size:256px;">
  </div>

  <!-- Teal Glow -->
  <div class="absolute pointer-events-none z-0"
    style="top:50%;left:50%;transform:translate(-50%,-52%);width:750px;height:750px;border-radius:50%;background:radial-gradient(circle,rgba(16,178,173,0.065) 0%,transparent 65%);">
  </div>

  <!-- Content -->
  <div class="relative z-20 text-center px-8 max-w-5xl mx-auto">

    <!-- Logo -->
    <div class="hero-logo mb-16 opacity-0">
      <!-- CUSTOMIZE: Logo -->
      <img src="/assets/logo.webp" alt="die Firma"
           class="mx-auto" style="height:3.5rem;width:auto;filter:invert(1);opacity:0.8;" loading="eager"/>
    </div>

    <!-- Headline -->
    <h1 class="hero-headline font-headline text-brand-white opacity-0"
        style="font-size:clamp(3rem,8vw,7.5rem);line-height:1.08;letter-spacing:-0.01em;margin-bottom:1.75rem;">
      <!-- CUSTOMIZE: Haupt-Headline -->
      Websites die<br/>
      <span class="shimmer-text">verkaufen.</span>
    </h1>

    <!-- Subline -->
    <p class="hero-subline font-body opacity-0 font-light"
       style="font-size:1.1rem;color:#d1d1d1;max-width:38rem;margin:0 auto 3.5rem;line-height:1.75;">
      <!-- CUSTOMIZE: Subline -->
      Fertig in 2 Wochen. PageSpeed 90+. Kein Baukasten. Kein Agentur-Overhead.
    </p>

    <!-- CTAs -->
    <div class="hero-cta opacity-0 flex flex-col sm:flex-row items-center justify-center gap-5">
      <!-- Primary: pill teal, kein Pfeil, custom cursor -->
      <a href="#kontakt" class="btn-pill-teal" data-cursor-cta>
        <!-- CUSTOMIZE: Primärer CTA -->
        Projekt anfragen
      </a>
      <!-- Secondary: pill outline -->
      <a href="#leistungen" class="btn-pill-outline" data-cursor-cta>
        <!-- CUSTOMIZE: Sekundärer CTA -->
        Leistungen ansehen
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0;opacity:0.6;">
          <path d="M7 3v8M3 9l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>

  </div>

  <!-- Scroll Indicator -->
  <div class="absolute bottom-10 left-1/2 z-20 flex flex-col items-center gap-2"
       style="transform:translateX(-50%);opacity:0.3;">
    <span class="font-body text-xs tracking-widest uppercase" style="color:#d1d1d1;">Scroll</span>
    <div class="w-px animate-pulse" style="height:3rem;background:rgba(209,209,209,0.5);"></div>
  </div>

</section>
