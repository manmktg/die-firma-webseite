---
// CUSTOMIZE: Prozess-Schritte
const schritte = [
  {
    nummer: '01',
    titel: 'Brief',
    beschreibung: 'Wir klären Ziel, Zielgruppe und Stil. Kein langer Onboarding-Prozess — nur die Infos die zählen.',
  },
  {
    nummer: '02',
    titel: 'Design',
    beschreibung: 'Innerhalb von 3 Tagen liegt ein vollständiger Design-Entwurf vor. Ein Feedback-Loop — dann Entwicklung.',
  },
  {
    nummer: '03',
    titel: 'Entwicklung',
    beschreibung: 'Astro, Tailwind, GSAP. Sauber gebaut, schnell geladen. Live-Vorschau auf Staging-URL inklusive.',
  },
  {
    nummer: '04',
    titel: 'Live',
    beschreibung: 'Übergabe mit Domain-Setup, Vercel-Deployment und SEO-Check. Fertig in 2 Wochen ab Brief.',
  },
];
---

<!-- SVG Ink Filter — einmalig, unsichtbar -->
<svg style="position:absolute;width:0;height:0;overflow:hidden;" aria-hidden="true">
  <defs>
    <filter id="ink-filter" x="-20%" y="-20%" width="140%" height="140%"
            color-interpolation-filters="sRGB">
      <feTurbulence
        id="ink-turb"
        type="turbulence"
        baseFrequency="0.035 0.065"
        numOctaves="4"
        seed="8"
        result="noise"/>
      <feDisplacementMap
        id="ink-disp"
        in="SourceGraphic"
        in2="noise"
        scale="180"
        xChannelSelector="R"
        yChannelSelector="G"
        result="displaced"/>
      <feGaussianBlur
        id="ink-blur"
        in="displaced"
        stdDeviation="12"
        result="blurred"/>
      <feMerge>
        <feMergeNode in="blurred"/>
      </feMerge>
    </filter>
  </defs>
</svg>

<!-- Section: 400vh für 4 Scroll-Steps -->
<section class="prozess-section relative" style="height:400vh;">

  <div class="prozess-sticky sticky top-0 h-screen overflow-hidden flex flex-col justify-center items-center">

    <!-- Dezente Hintergrundlinie -->
    <div class="absolute inset-0 pointer-events-none" style="background:linear-gradient(to bottom,rgba(16,178,173,0.02),transparent 40%);"></div>

    <!-- Header (statisch) -->
    <div class="absolute top-20 left-1/2 text-center w-full px-8" style="transform:translateX(-50%);">
      <p class="font-body text-xs tracking-[0.3em] uppercase" style="color:#10b2ad;">
        <!-- CUSTOMIZE: Section-Label -->
        Wie es läuft
      </p>
    </div>

    <!-- Dekorative große Nummer im Hintergrund -->
    <div class="prozess-bg-num absolute pointer-events-none select-none font-headline"
         style="font-size:clamp(20rem,35vw,40rem);line-height:1;color:rgba(255,255,255,0.015);top:50%;left:50%;transform:translate(-50%,-50%);transition:opacity 0.4s;">
      01
    </div>

    <!-- Content-Bereich (zentriert, wechselt per JS) -->
    <div class="relative z-10 text-center px-8 max-w-3xl mx-auto w-full">

      <!-- Step-Nummer -->
      <p class="prozess-step-indicator font-body text-sm tracking-[0.3em] mb-6 font-semibold"
         style="color:#10b2ad;">
        01 / 04
      </p>

      <!-- Step-Titel (Ink Splash Reveal via JS) -->
      <h2 class="prozess-step-title font-headline text-brand-white mb-8"
          style="font-size:clamp(3rem,8vw,7rem);line-height:1.05;opacity:0;letter-spacing:0.02em;">
      </h2>

      <!-- Step-Beschreibung -->
      <p class="prozess-step-desc font-body leading-relaxed max-w-xl mx-auto"
         style="color:#ffffff;font-size:1.05rem;">
        <!-- CUSTOMIZE: Wird durch JS gesetzt -->
        &nbsp;
      </p>

    </div>

    <!-- Teal Dot — Midpoint-Geste beim Step-Übergang -->
    <div class="prozess-teal-dot absolute pointer-events-none"
         style="width:4px;height:4px;border-radius:50%;background:#10b2ad;top:50%;left:50%;transform:translate(-50%,-50%);opacity:0;"></div>

    <!-- Progress Dots -->
    <div class="absolute bottom-12 left-1/2 flex gap-3" style="transform:translateX(-50%);">
      {schritte.map((_, i) => (
        <div
          class="prozess-dot"
          data-step={i}
          style={`width:${i === 0 ? '2rem' : '0.5rem'};height:2px;background:${i === 0 ? '#10b2ad' : 'rgba(255,255,255,0.2)'};transition:all 0.4s ease;`}
        />
      ))}
    </div>

  </div>

  <!-- Hidden Data für JS -->
  <div class="hidden" id="prozess-data" data-steps={JSON.stringify(schritte)}></div>

</section>
